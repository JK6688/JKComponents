{
  "name": "jk-vue-comps",
  "version": "0.2.11",
  "description": "jk-vue-comps",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "vite",
    "vue3",
    "tsx",
    "JK",
    "TelegramAuth",
    "GoogleAuth"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "ts:check": "tsc --project tsconfig.json --noEmitOnError",
    "delete:lib": "rimraf pnpm-lock.yaml node_modules",
    "delete:dist": "rimraf dist.zip dist",
    "delete:all": "pnpm delete:dist && pnpm delete:lib",
    "lint:ox": "oxlint . --fix -D no-undef",
    "lint:fmt": "oxfmt",
    "lint:all": "pnpm lint:fmt && pnpm lint:ox"
  },
  "dependencies": {
    "bignumber.js": "10.0.2",
    "vue": "3.5.30",
    "vue-types": "6.0.0"
  },
  "devDependencies": {
    "@types/node": "22.18.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "rimraf": "^6.1.3",
    "vue-tsc": "^3.2.5"
  }
}
